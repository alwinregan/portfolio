# Copy this file to .env and fill in your values

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/portfolio

PORT=4000

JWT_SECRET=<generate-a-long-random-string>
JWT_EXPIRES_IN=7d

ADMIN_USERNAME=alwin_regan
ADMIN_PASSWORD=<your-password>

# Storage: "local" stores uploads on disk, "s3" uses S3-compatible cloud storage
STORAGE_TYPE=local

# Only needed if STORAGE_TYPE=s3 (Backblaze B2)
# B2_ENDPOINT=
# B2_REGION=
# B2_KEY_ID=
# B2_APP_KEY=
# B2_BUCKET_NAME=

# Only needed if STORAGE_TYPE=r2 (Cloudflare R2)
# R2_ENDPOINT=
# R2_REGION=auto
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
